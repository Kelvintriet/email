# Cloudflare Worker Environment Variables
# Set these in: Cloudflare Dashboard → Workers & Pages → your-worker → Settings → Variables

# The full URL to your Next.js webhook route
WEBHOOK_URL=https://yourdomain.com/api/webhook/email

# Must match WEBHOOK_SECRET in your Next.js .env.local exactly
